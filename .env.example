# Database
DATABASE_URL=postgres://combine:combine@localhost:5432/combine_trade
DATABASE_URL_TEST=postgres://combine:combine@localhost:5432/combine_trade_test

# API Server
PORT=3000
NODE_ENV=development
ALLOWED_ORIGIN=http://localhost:3001
BETTER_AUTH_URL=http://localhost:3000

# Admin account (used by db:seed:admin)
ADMIN_EMAIL=admin@combine.trade
ADMIN_PASSWORD=changeme-on-first-login
ADMIN_NAME=Admin

# JWT
JWT_SECRET=change-me-in-production
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Master encryption key for exchange API keys stored per-user in DB (AES-256-GCM)
# Exchange API keys are registered via API and stored encrypted in exchange_credentials table.
# Generate: openssl rand -hex 32
MASTER_ENCRYPTION_KEY=change-me-in-production-64-hex-chars

# Logging
LOG_LEVEL=info
