{
	"name": "combine-trade",
	"private": true,
	"workspaces": ["apps/*", "packages/*", "workers/*"],
	"scripts": {
		"dev": "bun run --cwd apps/api dev",
		"build": "bun run typecheck",
		"test": "bun test --recursive",
		"lint": "bunx @biomejs/biome check .",
		"typecheck": "tsc --noEmit",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "drizzle-kit migrate"
	},
	"devDependencies": {
		"@biomejs/biome": "^1.9.0",
		"@faker-js/faker": "^10.3.0",
		"@types/bun": "latest",
		"@types/js-yaml": "^4.0.9",
		"drizzle-kit": "^0.31.10",
		"js-yaml": "^4.1.1",
		"typescript": "^5.7.0"
	},
	"dependencies": {
		"better-auth": "^1.5.6",
		"drizzle-orm": "^0.45.1",
		"elysiajs-helmet": "^1.0.4",
		"postgres": "^3.4.8"
	}
}
