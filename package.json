{
	"name": "combine-trade",
	"private": true,
	"workspaces": ["apps/*", "packages/*", "workers/*"],
	"scripts": {
		"dev": "bun run --filter '@combine/api' dev & bun run --filter '@combine/web' dev",
		"dev:api": "bun run --cwd apps/api dev",
		"dev:web": "bun run --cwd apps/web dev",
		"dev:desktop": "bun run --cwd apps/desktop dev",
		"build": "bun run typecheck",
		"test": "bun test --recursive",
		"test:unit": "bun test --recursive",
		"bench": "bun run scripts/bench.ts",
		"lint": "bunx @biomejs/biome check .",
		"typecheck": "tsc --noEmit",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "drizzle-kit migrate",
		"db:seed:admin": "bun run db/seed/admin.ts",
		"generate:icons": "bun scripts/generate-icons.ts"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.10",
		"@faker-js/faker": "^10.3.0",
		"@types/bun": "latest",
		"@types/js-yaml": "^4.0.9",
		"@types/sharp": "^0.32.0",
		"drizzle-kit": "^0.31.10",
		"js-yaml": "^4.1.1",
		"sharp": "^0.34.5",
		"typescript": "^5.7.0"
	},
	"dependencies": {
		"better-auth": "^1.5.6",
		"drizzle-orm": "^0.45.1",
		"elysiajs-helmet": "^1.0.4",
		"postgres": "^3.4.8"
	}
}
