                      "fill": "$text-primary",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "import { defineStrategy } from '@combine/core';\n\nexport default defineStrategy({\n  name: 'Momentum Breakout',\n  direction: 'LONG',\n  timeframe: '15m',\n\n  evaluate(ctx) {\n    const sma20 = ctx.sma(20);\n    const rsi = ctx.rsi(14);\n    const bb = ctx.bb(20, 2);\n\n    ctx.defineFeature('price_vs_sma',\n      ctx.candle.close / sma20 - 1,",
                      "lineHeight": 1.6,
                      "fontFamily": "JetBrains Mono",
                      "fontSize": 13,
                      "fontWeight": "normal"
                    }
