    "drizzle-orm": "^0.45.2",
    "fflate": "^0.8.2",
    "hono": "^4.12.10",
    "jsonwebtoken": "^9.0.3",
    "pgvector": "^0.2.1",
    "postgres": "^3.4.8",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router": "^7.14.0",
    "typescript": "^6.0.2",
    "zod": "^4.3.6",
