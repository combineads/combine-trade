{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Combine Trade",
  "version": "0.1.0",
  "identifier": "com.combine-trade.desktop",
  "build": {
    "beforeDevCommand": "bun run dev",
    "beforeBuildCommand": "bun run build",
    "devUrl": "http://localhost:3000",
    "frontendDist": "../out"
  },
  "app": {
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'unsafe-eval'; connect-src 'self' http://localhost:* https://api.*; style-src 'self' 'unsafe-inline'"
    },
    "windows": [
      {
        "title": "Combine Trade",
        "width": 1280,
        "height": 800,
        "resizable": true,
        "fullscreen": false
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png"
    ]
  }
}
